{
  "name": "reveal-math-activities",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "validate": "npm run validate:static && npm run validate:reveal-math",
    "validate:static": "node tools/validate-static-site.mjs",
    "validate:reveal-math": "node tools/validate-reveal-math-tools.mjs",
    "generate-notes": "node scripts/generate-notes.mjs",
    "generate-curriculum": "node scripts/generate-curriculum.mjs",
    "generate-lesson-novels": "node scripts/generate-lesson-novels.mjs",
    "generate-pdf": "node scripts/generate-pdf.mjs",
    "generate-docx": "node scripts/generate-docx.mjs",
    "generate-downloads": "node scripts/generate-notes.mjs && node scripts/generate-docx.mjs && node scripts/generate-pdf.mjs",
    "generate-homework": "node scripts/generate-homework.mjs",
    "generate-homework-html": "node scripts/generate-homework-html.mjs",
    "generate-mcap": "node scripts/generate-mcap-packets.mjs",
    "generate-registry": "node scripts/generate-registry.mjs",
    "generate-launch": "node scripts/generate-launch-manifest.mjs",
    "generate-mcap-index": "node scripts/generate-mcap-packet-index.mjs",
    "audit": "node scripts/audit-curriculum.mjs",
    "generate-activity-guides": "node scripts/generate-activity-teacher-docs.mjs",
    "generate-lesson-bonus-map": "node scripts/generate-lesson-bonus-map.mjs",
    "generate-lesson-family-homework-map": "node scripts/generate-lesson-family-homework-map.mjs",
    "generate-lesson-shells": "node scripts/generate-lesson-shells.mjs"
