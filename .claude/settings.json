{
  "permissions": {
    "allow": [
      "Bash(npm run validate)",
      "Bash(npm run validate:*)",
      "Bash(npm run build)",
      "Bash(npm run preview)",
      "Bash(npm run audit)",
      "Bash(npm run audit:*)",
      "Bash(npm install)",
      "Bash(npm ci)",
      "Bash(npm run qa:loop)",
      "Bash(npm run qa:danger:*)",
      "Bash(npm run format)",
      "Bash(npm run prettier)",
      "Bash(bash scripts/qa-loop.sh)",
      "Bash(bash scripts/check-dangerous-commands.sh:*)",
      "Bash(node tools/audit-save-resume-integration.js)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git switch:*)",
      "Bash(git stash list)",
      "Bash(pwd)",
      "Bash(cat:*)",
      "Bash(sed:*)",
      "Bash(awk:*)",
      "Bash(find:*)",
      "Bash(rg:*)",
      "Bash(grep:*)",
      "Bash(fd:*)",
      "Bash(ls:*)"
    ],
    "deny": [
      "Bash(wrangler deploy:*)",
      "Bash(npx wrangler deploy:*)",
      "Bash(wrangler pages deploy:*)",
      "Bash(npx wrangler pages deploy:*)",
      "Bash(npm run deploy)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd:*)",
      "Bash(rm -rf:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pre-bash-guard.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post-edit-format.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/stop-qa-reminder.sh"
          }
        ]
      }
    ]
  }
}
