{
  "permissions": {
    "allow": [
      "Bash(npm run validate)",
      "Bash(npm run validate:*)",
      "Bash(npm run build)",
      "Bash(npm run preview)",
      "Bash(npm run audit)",
      "Bash(npm run audit:*)",
      "Bash(npm install)",
      "Bash(npm ci)",
      "Bash(node tools/audit-save-resume-integration.js)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git switch:*)",
      "Bash(git stash list)",
      "Bash(rg:*)",
      "Bash(grep:*)",
      "Bash(fd:*)",
      "Bash(ls:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  }
}
