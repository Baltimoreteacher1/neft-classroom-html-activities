# Cloudflare Pages config example for neft-classroom-html-activities.
# This file is intentionally an example because Pages project settings may already be managed in the Cloudflare dashboard.
# Do not put secrets in this file.

name = "neft-classroom-html-activities"
compatibility_date = "2026-05-25"
pages_build_output_dir = "."

[vars]
APP_BASE_URL = "https://neft-classroom-html-activities.pages.dev"
GOOGLE_CLIENT_ID = "<GOOGLE_CLIENT_ID>"

[[kv_namespaces]]
binding = "NOAM_SCHOOL_KV"
id = "<NOAM_SCHOOL_KV_NAMESPACE_ID>"

# Add GOOGLE_CLIENT_SECRET as a Pages secret in the Cloudflare dashboard.
# Binding name must be exactly NOAM_SCHOOL_KV because the functions use env.NOAM_SCHOOL_KV.
