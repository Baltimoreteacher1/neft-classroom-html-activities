  "learn": {
    "heading": "Multiply fractions & flip",
    "intro": "<p>To <strong>multiply fractions</strong>: multiply the tops, multiply the bottoms. The <strong>reciprocal</strong> of a fraction is that fraction flipped upside down — swap top and bottom. These two moves are the engine of fraction division.</p>",
    "examples": [
      "<strong>Multiply:</strong> 2/3 × 1/2 = (2×1)/(3×2) = 2/6 = 1/3.",
      "<strong>Flip:</strong> the reciprocal of 3/4 is 4/3 (just swap top and bottom)."
    ]
  },
