  "learn": {
    "heading": "Scaling to reason",
    "intro": "<p><strong>Ratio reasoning</strong> means scaling a known ratio to fit a new amount. Multiply both numbers to grow it, or divide both to shrink it.</p>",
    "examples": [
      "If 2 apples cost $1, then 6 apples cost $3 — multiply both by 3.",
      "If 10 cookies feed 5 kids, then 2 cookies feed 1 kid — divide both by 5."
    ]
  },
  "tiers": [
    {
      "level": 0,
      "intro": "Scale up one step at a time.",
      "items": [
        {
          "type": "num",
          "q": "A. 1 pencil costs $2. Two pencils cost 2 × $2 = $___?",
          "ans": 4,
          "hint": "2 × 2 = 4."
        },
        {
          "type": "num",
          "q": "B. Three pencils cost 3 × $2 = $___?",
          "ans": 6,
          "hint": "3 × 2 = 6."
        },
        {
          "type": "num",
          "q": "C. So 4 pencils cost 4 × $2 = $___?",
          "ans": 8,
          "hint": "4 × 2 = 8."
        }
      ]
    },
    {
      "level": 1,
      "intro": "Scale down by dividing.",
      "items": [
        {
          "type": "num",
          "q": "A. 12 stickers are shared into 3 equal bags. Each bag has 12 ÷ 3 = ___?",
          "ans": 4,
          "hint": "12 ÷ 3 = 4."
        },
        {
          "type": "num",
          "q": "B. 15 marbles in 5 cups, equally. Each cup has 15 ÷ 5 = ___?",
          "ans": 3,
          "hint": "15 ÷ 5 = 3."
        }
      ]
    },
    {
      "level": 2,
      "intro": "Reason with a full ratio.",
      "items": [
        {
          "type": "num",
          "q": "A. 2 cups of flour make 6 muffins. To make 12 muffins (double), you need ___ cups of flour?",
          "ans": 4,
          "hint": "Muffins doubled (6→12), so flour doubles: 2 × 2 = 4."
        },
        {
          "type": "mc",
          "q": "B. 3 pens cost $6. How much do 5 pens cost? (First find 1 pen.)",
          "ans": "c",
          "opts": [
            { "v": "a", "t": "$8" },
            { "v": "b", "t": "$9" },
            { "v": "c", "t": "$10" },
            { "v": "d", "t": "$15" }
          ],
          "hint": "1 pen = $6 ÷ 3 = $2, so 5 pens = 5 × $2 = $10."
        }
      ]
    }
  ],
  "exit": [
