  "learn": {
    "heading": "What is repeated multiplication?",
    "intro": "<p>An <strong>exponent</strong> tells you how many times to multiply a number by itself. The big number is the <strong>base</strong>; the small raised number is the <strong>exponent</strong>.</p>",
    "examples": [
      "<strong>2³</strong> means use 2 three times: 2 × 2 × 2 = <strong>8</strong>.",
      "<strong>5²</strong> means use 5 two times: 5 × 5 = <strong>25</strong>. (5² is read 'five squared'.)"
    ]
  },
