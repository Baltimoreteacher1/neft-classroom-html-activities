  "learn": {
    "heading": "Math words become symbols",
    "intro": "<p>Each math word points to one operation: <strong>sum</strong> = +, <strong>difference</strong> = −, <strong>product</strong> = ×, <strong>quotient</strong> = ÷. A letter like <em>n</em> stands for a number we don't know yet.</p>",
    "examples": [
      "'The <strong>sum</strong> of a number and 5' becomes <strong>n + 5</strong>.",
      "'The <strong>product</strong> of 3 and a number' becomes <strong>3 × n</strong> (often written 3n)."
    ]
  },
