  "learn": {
    "heading": "Line up the points",
    "intro": "<p>To add or subtract decimals, stack the numbers so the <strong>decimal points line up</strong> — that keeps tenths over tenths and hundredths over hundredths. Then add or subtract like whole numbers and drop the point straight down.</p>",
    "examples": [
      "<strong>2.5 + 1.3:</strong> line up the points → 5 tenths + 3 tenths = 8 tenths, 2 + 1 = 3. Answer = <strong>3.8</strong>.",
      "<strong>4.6 − 1.2:</strong> 6 tenths − 2 tenths = 4 tenths, 4 − 1 = 3. Answer = <strong>3.4</strong>."
    ]
  },
