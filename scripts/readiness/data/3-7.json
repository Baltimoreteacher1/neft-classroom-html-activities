  "learn": {
    "heading": "Find the unit rate",
    "intro": "<p>A <strong>unit rate</strong> is the amount for <em>just one</em>. Find it by dividing. Once you know the rate for one, multiply to scale up to any amount.</p>",
    "examples": [
      "$12 for 4 tickets → $12 ÷ 4 = <strong>$3 per ticket</strong>. That's the unit rate.",
      "Now scale: 7 tickets cost 7 × $3 = <strong>$21</strong>."
    ]
  },
