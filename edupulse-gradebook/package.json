{
  "name": "edupulse-gradebook",
  "version": "1.0.0",
  "private": true,
  "description": "Score-ingestion + gradebook system: Cloudflare Worker + D1 API and a zero-dependency dashboard.",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 migrations apply edupulse-gradebook --remote",
    "db:migrate:local": "wrangler d1 migrations apply edupulse-gradebook --local",
    "pages:deploy": "wrangler pages deploy public --project-name edupulse-gradebook",
    "test": "node test/worker.test.mjs"
  },
  "devDependencies": {
    "wrangler": "^3.90.0"
  }
}
