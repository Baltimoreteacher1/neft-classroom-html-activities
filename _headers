# Cloudflare Pages custom headers for Neft Teacher static activity hub
# Keep this file in the repository root because the build output directory is the repository root.

/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=()

/*.html
  Cache-Control: public, max-age=0, must-revalidate

/
  Cache-Control: public, max-age=0, must-revalidate

/assets/*
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

/teacher-tools/*.css
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

/teacher-tools/*.js
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

/teacher-tools/neftos-command-center/*.css
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

/teacher-tools/neftos-command-center/*.js
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

/teacher-tools/neftos-command-center/service-worker.js
  Cache-Control: public, max-age=0, must-revalidate
  Service-Worker-Allowed: /teacher-tools/neftos-command-center/

/teacher-tools/neftos-command-center/manifest.json
  Cache-Control: public, max-age=0, must-revalidate
  Content-Type: application/manifest+json; charset=utf-8
