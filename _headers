# Cloudflare Pages custom headers for Neft Teacher static activity hub
# Keep this file in the repository root because the build output directory is the repository root.

# Default for everything: security headers + ALWAYS-REVALIDATE caching.
# max-age=0, must-revalidate means the browser checks with the server (ETag) on
# every load and gets a cheap 304 when unchanged — so updated pages, tool scripts
# (app.js/css), data files, games, and WIDA studios appear immediately, with no
# hard refresh needed.
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=()
  Cache-Control: public, max-age=0, must-revalidate

# Vite build output is content-hashed (filename changes whenever content changes),
# so these are safe to cache for a long time / immutable.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# ACCESS Practice Lab HTML shell: NEVER cache the entry pages, so a deploy is
# seen immediately (the versioned ?v= app.js/data underneath still cache fine).
# This is the SPA hub + the clean activity/test URLs served by the Pages Function.
/access-practice-lab/
  Cache-Control: no-store
/access-teacher/
  Cache-Control: no-store

# Command Center PWA: service worker and manifest must always revalidate.
/teacher-tools/neftos-command-center/service-worker.js
  Cache-Control: public, max-age=0, must-revalidate
  Service-Worker-Allowed: /teacher-tools/neftos-command-center/

/teacher-tools/neftos-command-center/manifest.json
  Cache-Control: public, max-age=0, must-revalidate
  Content-Type: application/manifest+json; charset=utf-8
