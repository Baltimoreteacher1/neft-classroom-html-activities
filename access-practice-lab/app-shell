<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ACCESS Practice Lab</title>
    <meta
      name="description"
      content="Student-friendly WIDA ACCESS practice for listening, speaking, reading, and writing."
    />
    <link
      rel="icon"
      href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Crect width='64' height='64' rx='12' fill='%231f766f'/%3E%3Ctext x='32' y='40' text-anchor='middle' font-size='26' font-family='Arial' font-weight='700' fill='white'%3EA%3C/text%3E%3C/svg%3E"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Atkinson+Hyperlegible:wght@400;700&family=Nunito:wght@600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/access-practice-lab/styles.css?v=20260612-all-domains" />
  </head>
  <body class="mode-hub">
    <a class="skip-link" href="#mainContent">Skip to content</a>
    <div class="lab-shell">
      <header class="site-header">
        <nav class="top-nav" aria-label="Site navigation">
          <div class="nav-left"></div>
          <div class="nav-right">
            <button class="ghost-btn" type="button" id="printBtn">Print</button>
          </div>
        </nav>
      </header>

      <div id="hubView" class="hub-view">
        <header class="hub-hero" id="labHero">
          <p class="eyebrow" id="hubEyebrow">Teacher dashboard</p>
          <h1 id="hubTitle">ACCESS Practice Lab</h1>
          <p class="hub-lead" id="hubLead">
            Pick a domain and level, then share a direct practice link with students.
          </p>
        </header>

        <section class="hub-section hub-section-root" id="rootDomainSection" aria-labelledby="rootDomainTitle">
          <h2 id="rootDomainTitle">All practice domains</h2>
          <p class="muted">Choose a domain to browse levels and copy student links.</p>
          <div class="domain-overview-grid" id="domainOverviewGrid"></div>
        </section>

        <section class="hub-section hub-section-domain" id="domainNavSection" aria-labelledby="domainNavTitle">
          <h2 id="domainNavTitle">Domains</h2>
          <div class="domain-tabs" id="domainTabs" role="tablist" aria-label="Practice domains"></div>
        </section>

        <section class="hub-section hub-section-level" id="levelNavSection" aria-labelledby="levelNavTitle">
          <h2 id="levelNavTitle">Levels</h2>
          <div class="level-tabs" id="hubLevelTabs"></div>
        </section>

        <section class="hub-section hub-section-activities" id="activityGridSection" aria-labelledby="activityGridTitle">
          <div class="section-heading">
            <h2 id="activityGridTitle">Activities</h2>
            <p id="activityGridSubtitle">Open a practice page or copy a link for Google Classroom.</p>
          </div>
          <div class="activity-grid" id="activityGrid"></div>
        </section>

        <details class="teacher-drawer" id="hubTeacherDrawer">
          <summary>For teachers — links, notes &amp; progress</summary>
          <div class="teacher-drawer-body">
            <section class="teacher-block" aria-labelledby="goalTitle">
              <h3 id="goalTitle">Student goal</h3>
              <p id="studentGoal">I can practice ACCESS skills one step at a time.</p>
              <p class="objective" id="studentObjective"></p>
            </section>

            <section class="teacher-block learner-tools" aria-label="Progress tools">
              <label>
                <span>Student name (optional)</span>
                <input id="studentName" type="text" autocomplete="name" placeholder="First name or initials" />
              </label>
              <div class="tool-actions">
                <button type="button" id="exportBtn">Copy progress summary</button>
                <button type="button" id="resetProgressBtn">Reset this path</button>
              </div>
              <p id="saveStatus" role="status" aria-live="polite">Progress saves on this device.</p>
            </section>

            <section class="teacher-block" aria-labelledby="linkBoardTitle">
              <h3 id="linkBoardTitle">Share links — all activities</h3>
              <p class="muted">Copy any URL below when assigning a specific activity.</p>
              <div class="link-board-grid" id="linkBoardGrid"></div>
            </section>

            <section class="teacher-block" aria-labelledby="quickLinksTitle">
              <h3 id="quickLinksTitle">Quick paths</h3>
              <div class="quick-test-links" id="quickTestLinks"></div>
            </section>
          </div>
        </details>
      </div>

      <div id="practiceView" class="practice-view">
        <header class="practice-hero">
          <p class="practice-meta" id="practiceMeta"></p>
          <div class="practice-level-switch" id="practiceLevelSwitch" aria-label="Switch level"></div>
        </header>

        <main
          class="practice-main"
          id="mainContent"
          aria-live="polite"
          aria-labelledby="activityTitle"
        >
          <section class="activity-panel" id="activityPanel"></section>
        </main>

        <details class="teacher-drawer practice-teacher" id="practiceTeacherDrawer">
          <summary>For teachers</summary>
          <div class="teacher-drawer-body" id="practiceTeacherPanel"></div>
        </details>
      </div>
    </div>

    <script src="/access-practice-lab/access-data.js?v=20260612-all-domains"></script>
    <script src="/access-practice-lab/app.js?v=20260612-all-domains"></script>
  </body>
</html>
