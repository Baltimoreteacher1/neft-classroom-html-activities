<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ACCESS Practice Lab | EduWonderLab</title>
    <meta
      name="description"
      content="Student-friendly WIDA ACCESS practice for listening, speaking, reading, and writing."
    />
    <link
      rel="icon"
      href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Crect width='64' height='64' rx='12' fill='%231f766f'/%3E%3Ctext x='32' y='40' text-anchor='middle' font-size='26' font-family='Arial' font-weight='700' fill='white'%3EA%3C/text%3E%3C/svg%3E"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Atkinson+Hyperlegible:wght@400;700&family=Nunito:wght@600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/access-practice-lab/styles.css?v=20260612-polish" />
  </head>
  <body>
    <a class="skip-link" href="#activityPanel">Skip to activity</a>
    <div class="lab-shell">
      <header class="lab-hero" id="labHero">
        <nav class="top-nav" aria-label="Practice navigation">
          <a class="home-link" href="/">EduWonderLab</a>
          <button class="print-btn" type="button" id="printBtn">Print practice</button>
        </nav>

        <div class="hero-grid">
          <div class="hero-copy">
            <p class="eyebrow" id="breadcrumb">ACCESS Practice Lab</p>
            <h1 id="pageTitle">ACCESS Practice Lab</h1>
            <p class="hero-subtitle" id="pageSubtitle">
              Choose a domain and level to begin.
            </p>
            <div class="meta-row" id="metaRow" aria-label="Practice details"></div>
            <div class="level-strip" id="levelGrid" aria-label="Available levels"></div>
          </div>
          <section class="goal-card" aria-labelledby="goalTitle">
            <h2 id="goalTitle">Student Goal</h2>
            <p id="studentGoal">I can practice ACCESS skills one step at a time.</p>
            <p class="objective" id="studentObjective"></p>
          </section>
        </div>
      </header>

      <main class="lab-main">
        <section class="learner-tools" aria-label="Student tools">
          <label>
            <span>Student name</span>
            <input id="studentName" type="text" autocomplete="name" placeholder="Type first name or initials" />
          </label>
          <div class="tool-actions">
            <button type="button" id="exportBtn">Copy progress summary</button>
            <button type="button" id="resetProgressBtn">Reset this path</button>
          </div>
          <p id="saveStatus" role="status" aria-live="polite">Progress saves on this device.</p>
        </section>

        <section class="progress-panel" aria-label="Progress">
          <div class="progress-copy">
            <strong id="progressSummary">0 of 0 activities complete</strong>
            <span id="progressDetail">Start with Activity 1.</span>
          </div>
          <div class="progress-track" aria-hidden="true">
            <div class="progress-fill" id="progressFill"></div>
          </div>
        </section>

        <section class="layout-grid">
          <aside class="activity-list" aria-labelledby="activityListTitle">
            <h2 id="activityListTitle">Practice Path</h2>
            <div id="activityList"></div>
          </aside>

          <section
            class="activity-panel"
            id="activityPanel"
            aria-live="polite"
            aria-labelledby="activityTitle"
          ></section>
        </section>

        <details class="more-practice" id="morePractice">
          <summary>More practice options &amp; share links</summary>
          <div class="more-practice-body">
            <section class="domain-panel" aria-labelledby="chooseTitle">
              <div class="section-heading">
                <h2 id="chooseTitle">Choose Another Practice</h2>
                <p id="chooseSubtitle">Switch domains without losing your current progress.</p>
              </div>
              <div class="quick-test-links" aria-label="Practice quick links">
                <a href="/access-practice-lab/Listening/A/classroom-directions">
                  <strong>Listening Level A</strong>
                  <span>Directions, main ideas, details, and evidence</span>
                </a>
                <a href="/access-practice-lab/Listening/B/classroom-directions">
                  <strong>Listening Level B</strong>
                  <span>Inference, cause/effect, and academic listening</span>
                </a>
                <a href="/access-practice-lab/Model-Test/6-8/A/model-68-a-start">
                  <strong>Model Practice Test Part A</strong>
                  <span>Grades 6-8 ACCESS-style practice</span>
                </a>
                <a href="/access-practice-lab/Model-Test/6-8/B/model-68-b-listening-1">
                  <strong>Model Practice Test Part B</strong>
                  <span>Second grades 6-8 practice set</span>
                </a>
              </div>
              <div class="domain-grid" id="domainGrid"></div>
            </section>

            <section class="link-board" aria-labelledby="linkBoardTitle">
              <div class="section-heading">
                <h2 id="linkBoardTitle">Student Link Board</h2>
                <p>Use these direct pages when sending a specific activity to students.</p>
              </div>
              <div class="link-board-grid" id="linkBoardGrid"></div>
            </section>
          </div>
        </details>
      </main>
    </div>

    <script src="/access-practice-lab/access-data.js?v=20260612-polish"></script>
    <script src="/access-practice-lab/app.js?v=20260612-polish"></script>
  </body>
</html>
