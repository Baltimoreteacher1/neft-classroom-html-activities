  "contentObjective": "I can divide multi-digit whole numbers and explain the meaning of the quotient and remainder.",
  "languageObjective": "I can explain my division using the words dividend, divisor, quotient, and remainder.",
  "vocabulary": [
    {
      "term": "Dividend",
      "termEs": "Dividendo",
      "definition": "The number being divided",
      "definitionEs": "El número que se divide",
      "visual": "In 156 ÷ 12 = 13, the dividend is 156 — it is the total being split up",
      "cloze": "In 84 ÷ 7, the number 84 being divided is the ___."
    },
    {
      "term": "Divisor",
      "termEs": "Divisor",
      "definition": "The number you divide by",
      "definitionEs": "El número entre el que se divide",
      "visual": "In 156 ÷ 12 = 13, the divisor is 12 — it is the size of each group",
      "cloze": "In 84 ÷ 7, the number 7 that we divide by is the ___."
    },
    {
      "term": "Quotient",
      "termEs": "Cociente",
      "definition": "The answer to a division problem",
      "definitionEs": "El resultado de un problema de división",
      "visual": "In 156 ÷ 12 = 13, the quotient is 13 — there are 13 groups",
      "cloze": "The answer to a division problem is called the ___."
    },
    {
      "term": "Remainder",
      "termEs": "Residuo",
      "definition": "The amount left over when a number does not divide evenly",
      "definitionEs": "La cantidad que sobra cuando un número no se divide exactamente",
      "visual": "17 ÷ 5 = 3 R 2 means 3 groups of 5 with 2 left over",
      "cloze": "When a number does not divide evenly, the amount left over is the ___.",
      "examples": [
        {
          "text": "17 ÷ 5 has a remainder of 2",
          "isExample": true,
          "why": "5 × 3 = 15, and 17 − 15 = 2."
        },
        {
          "text": "20 ÷ 5 has a remainder of 0",
          "isExample": false,
          "why": "20 divides evenly by 5, so there is no remainder."
        }
      ]
    },
    {
      "term": "Partial quotients",
      "termEs": "Cocientes parciales",
      "definition": "A division strategy that breaks the problem into easier chunks",
      "definitionEs": "Una estrategia de división que separa el problema en partes más fáciles",
      "visual": "1,344 ÷ 12: first 12 × 100 = 1,200, then 12 × 12 = 144. Quotient = 100 + 12 = 112",
      "cloze": "Breaking division into easier chunks and adding the pieces uses ___."
    }
  ],
