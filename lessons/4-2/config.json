  "contentObjective": "I can write equivalent fractions, decimals, and percents for the same value.",
  "languageObjective": "I can explain my conversions using the words percent, decimal, equivalent, and benchmark.",
  "vocabMode": "matching",
  "vocabulary": [
    {
      "term": "Percent",
      "termEs": "Porcentaje",
      "definition": "A way to compare a number to 100, shown with the % sign.",
      "definitionEs": "Una manera de comparar un número con 100, con el signo %.",
      "visual": "25% means 25 out of 100",
      "cloze": "A ratio that compares a number to 100, written with a % sign, is a ___."
    },
    {
      "term": "Decimal",
      "termEs": "Decimal",
      "definition": "A number with a dot, like 0.5, that shows a part.",
      "definitionEs": "Un número con un punto, como 0.5, que muestra una parte.",
      "visual": "0.75 means seventy-five hundredths",
      "cloze": "A number that uses a point to show parts of a whole is a ___."
    },
    {
      "term": "Equivalent",
      "termEs": "Equivalente",
      "definition": "Having the same value, just written a different way.",
      "definitionEs": "Tener el mismo valor, escrito de otra forma.",
      "visual": "1/2 = 0.5 = 50%",
      "sentences": [
        {
          "text": "1/2, 0.5, and 50% are equivalent.",
          "correct": true
        },
        {
          "text": "1/2 and 25% are equivalent.",
          "correct": false
        }
      ]
    },
    {
      "term": "Benchmark",
      "termEs": "Referencia",
      "definition": "A familiar number you use to guess, like 50% or 1/2.",
      "definitionEs": "Un número conocido que usas para estimar, como 50% o 1/2.",
      "visual": "Common benchmarks: 25%, 50%, 75%",
      "cloze": "A common, easy-to-remember value like 50% or 1/4 used for comparing is a ___."
    },
    {
      "term": "Discount",
      "termEs": "Descuento",
      "definition": "Money taken off the first price to make it cheaper.",
      "definitionEs": "Dinero que se quita del precio original para que sea más barato.",
      "visual": "$40 shirt at 25% off: discount = $10",
      "cloze": "An amount taken off a price, often given as a percent, is a ___."
    }
  ],
